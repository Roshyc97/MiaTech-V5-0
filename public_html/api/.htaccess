# public_html/api/.htaccess — enruta todo /api/* al front controller (index.php)

# Evita que Apache resuelva /api/config -> settings.php por content-negotiation
# (MultiViews). El cargador se renombro a settings.php para eliminar la colision
# de nombre con la URL /api/config que provocaba el 403.
Options -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /api/

    # Si el recurso fisico existe, servirlo directo (no aplica a rutas de la API)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Todo lo demas -> index.php (conserva query string)
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# El unico punto de entrada es index.php: bloquear acceso directo a internos
<FilesMatch "^(settings|bootstrap)\.php$">
    Require all denied
</FilesMatch>
<FilesMatch "\.(env|sqlite|db|log)$">
    Require all denied
</FilesMatch>

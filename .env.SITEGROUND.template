# ============================================================
#  MiaTech v5 (PHP) — .env SITEGROUND
#
#  INSTRUCCIONES:
#  1. Copiar este contenido
#  2. Reemplazar todos los valores XXXX con datos reales de Site Tools
#  3. Crear archivo .env en /home/customer/www/institutoj20.sg-host.com/
#  4. Permisos: chmod 600 .env
#  5. NUNCA subir a git
# ============================================================

# ============================================================
# ENTORNO
# ============================================================
APP_ENV=production
APP_DEBUG=false
APP_BASE_URL=https://institutoj20.sg-host.com
PERIODO_ACADEMICO=2025B

# ============================================================
# BASE DE DATOS — MySQL (desde SiteGround Site Tools → MySQL)
# ============================================================
DB_DRIVER=mysql

# Datos a copiar de Site Tools:
DB_HOST=XXXX_MYSQL_HOST_XXXX
# Típicamente: localhost
DB_PORT=3306
DB_NAME=XXXX_NOMBRE_BD_XXXX
# Ejemplo: miatech
DB_USER=XXXX_USUARIO_MYSQL_XXXX
# Ejemplo: miatech_user
DB_PASSWORD=XXXX_CONTRASEÑA_MYSQL_XXXX
# Contraseña del usuario MySQL
DB_CHARSET=utf8mb4

# NO USAR (solo para SQLite local):
# DB_SQLITE_PATH=

# ============================================================
# ALMACENAMIENTO
# ============================================================
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=/home/customer/www/institutoj20.sg-host.com/storage

# ============================================================
# GROQ (IA: Transcripción + Evaluación CEFR)
# ============================================================
# Obtén clave: https://console.groq.com/keys
# IMPORTANTE: Cambiar a plan de pago (free tier tiene límites bajos)
GROQ_API_KEY=XXXX_GROQ_API_KEY_XXXX
# Ejemplo: gsk_abcdef1234567890xyz
GROQ_MODEL=openai/gpt-oss-120b
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ============================================================
# SMTP (Correo electrónico — speakingtest@itsjapon.edu.ec)
# ============================================================
# Verificar con TI:
# - ¿Usar Gmail, SiteGround, o servidor externo?
# - ¿Qué puerto? (587 = STARTTLS, 465 = SSL)
# - ¿Contraseña normal o contraseña de app?

SMTP_HOST=XXXX_SMTP_HOST_XXXX
# Opciones comunes:
#   - Gmail: smtp.gmail.com
#   - SiteGround: mail.institutoj20.sg-host.com (verificar)
#   - Otro: consultar con proveedor

SMTP_PORT=587
# O 465 si usas SSL

SMTP_USER=speakingtest@itsjapon.edu.ec
# Usuario del correo (puede ser igual al FROM)

SMTP_PASSWORD=XXXX_CONTRASEÑA_SMTP_XXXX
# Contraseña del correo o contraseña de app

SMTP_FROM=speakingtest@itsjapon.edu.ec
SMTP_FROM_NAME=MiaTech - Centro de Idiomas

# ============================================================
# ONEDRIVE (Futuro — pendiente de setup en Entra ID)
# ============================================================
# DEJAR VACÍOS POR AHORA
ONEDRIVE_TENANT_ID=
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_DRIVE_ID=
ONEDRIVE_BASE_FOLDER=MiaTech

# ============================================================
# GRABACIÓN DE AUDIO (no cambiar, valores estándar)
# ============================================================
MIN_RECORDING_DURATION=60
MAX_RECORDING_DURATION=300
RECORDING_TIME_LABEL=1-5 min
TASK_TEXT=Describe the picture.
IMAGE_PATH=./public_html/img/imagenes/

# ============================================================
# FFMPEG (disponible en SiteGround)
# ============================================================
FFMPEG_BIN=ffmpeg
# O ruta absoluta si no está en PATH: /usr/bin/ffmpeg

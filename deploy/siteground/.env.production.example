# ============================================================
#  MiaTech v5 (PHP) — .env PRODUCTION (SITEGROUND) EJEMPLO
#
#  IMPORTANTE: Este archivo es un TEMPLATE/EJEMPLO sin secretos
#  1. Copiar este contenido a un nuevo archivo .env en la raíz de SiteGround
#  2. Reemplazar TODOS los valores XXXX con datos REALES
#  3. NUNCA commitear el .env.production real a git (contiene secretos)
#  4. Permisos en servidor: chmod 600 .env
# ============================================================

# ============================================================
# ENTORNO — Producción
# ============================================================
APP_ENV=production

APP_DEBUG=false

APP_BASE_URL=https://institutoj20.sg-host.com
# URL pública del sitio (con HTTPS)

PERIODO_ACADEMICO=2025B
# Período académico actual. Puede cambiar según necesidad.

# ============================================================
# BASE DE DATOS — MySQL en SiteGround
# ============================================================

DB_DRIVER=mysql

DB_HOST=localhost
#DB_HOST=ftp.institutoj20.sg-host.com
# Dónde obtener: SiteGround → Site Tools → MySQL

DB_PORT=3306
# Puerto MySQL estándar. Usualmente 3306.

DB_NAME=db_xxx_production
# Dónde obtener: SiteGround → Site Tools → MySQL
# Crear BD y anotar el nombre exacto
# Ejemplo: miatech_bd

DB_USER=user_xxx_production
# Dónde obtener: SiteGround → Site Tools → MySQL
# Crear usuario MySQL y asignar a la BD
# Ejemplo: miatech_user

DB_PASSWORD=xxxxx_PASSWORD_REAL_xxxxx
# Dónde obtener: SiteGround → Site Tools → MySQL
# Contraseña del usuario MySQL creado
# ⚠️ SECRETO: NO exponer, guardar de forma segura

DB_CHARSET=utf8mb4
# Codificación. Dejar como está.

# NO NECESARIO EN SITEGROUND (solo para SQLite local):
# DB_SQLITE_PATH=

# ============================================================
# ALMACENAMIENTO — Local en SiteGround
# ============================================================

STORAGE_DRIVER=local
# driver activo: local (o onedrive en futuro)

STORAGE_LOCAL_PATH=/home/customer/www/institutoj20.sg-host.com/storage
# Dónde obtener: Ruta del servidor SiteGround
# Esta es la ruta ABSOLUTA donde se guardan videos y PDFs
# Debe estar FUERA de public_html/ (por seguridad)
# Asegurarse de que la carpeta existe y es escribible (chmod 755)

# ============================================================
# GROQ (IA: Transcripción + Evaluación CEFR)
# ============================================================

GROQ_API_KEY=gsk_xxxxxxxxxxxxx_PASTE_REAL_KEY_HERE_xxxxxxxxxxxxx
# Dónde obtener: https://console.groq.com/keys
# ⚠️ SECRETO: NO exponer en logs/pantalla
# ⚠️ Free tier tiene límites: max 9,000 tokens/min
#    Si hay muchas evaluaciones simultáneas, cambiar a plan pago

GROQ_MODEL=openai/gpt-oss-120b
# Modelo para evaluación CEFR. Dejar como está.

GROQ_WHISPER_MODEL=whisper-large-v3-turbo
# Modelo para transcripción de audio. Dejar como está.

GROQ_BASE_URL=https://api.groq.com/openai/v1
# URL del API de GROQ. Dejar como está.

# ============================================================
# SMTP (Correo electrónico — speakingtest@itsjapon.edu.ec)
# ============================================================

SMTP_HOST=smtp.office365.com
# Dónde obtener: Preguntar a TI o administrador
# Opciones comunes:
#   - Gmail: smtp.gmail.com
#   - SiteGround (en el mismo servidor): mail.institutoj20.sg-host.com (verificar)
#   - Servidor corporativo: preguntar a TI
# Típicamente SiteGround proporciona SMTP en el mismo servidor.

SMTP_PORT=587
# Opciones:
#   - 587: STARTTLS (inicio seguro, luego encriptación)
#   - 465: SSL (encriptación desde el inicio)
# Dónde obtener: Consultar con proveedor de email
# Típicamente: 587 para Gmail, verificar para SiteGround

SMTP_USER=speakingtest@itsjapon.edu.ec
# Usuario del correo (email completo)
# Dónde obtener: Credenciales del correo institucional

SMTP_PASSWORD=xxxxx_EMAIL_PASSWORD_REAL_xxxxx
# CAMBIO CRÍTICO: Contraseña REAL del correo
# ⚠️ SECRETO: NO exponer

SMTP_FROM=speakingtest@itsjapon.edu.ec
# Dirección de "from" (de dónde sale el email). Dejar como está.

SMTP_FROM_NAME=MiaTech - Centro de Idiomas - ITS Japón
# Nombre que aparece en "De:" en los correos. Dejar como está.

# ============================================================
# ONEDRIVE (Futuro — PENDIENTE DE SETUP)
# ============================================================
# NO USAR TODAVÍA. Estos valores se usarán cuando OneDrive esté listo.
# Requiere registro de app en Entra ID (Azure) — TBD con TI

ONEDRIVE_TENANT_ID=
# Dónde obtener: Entra ID (Azure) → App registrations
# Dejar vacío por ahora

ONEDRIVE_CLIENT_ID=
# Dónde obtener: Entra ID → App registered
# Dejar vacío por ahora

ONEDRIVE_CLIENT_SECRET=
# Dónde obtener: Entra ID → Client secrets
# ⚠️ SECRETO
# Dejar vacío por ahora

ONEDRIVE_DRIVE_ID=
# Dónde obtener: Microsoft Graph
# Dejar vacío por ahora

ONEDRIVE_BASE_FOLDER=MiaTech
# Carpeta base en OneDrive. Por defecto: MiaTech

# ============================================================
# GRABACIÓN DE AUDIO (Configuración de límites)
# ============================================================

MIN_RECORDING_DURATION=60
# Duración mínima de grabación en segundos (60 = 1 minuto)
# Dejar como está

MAX_RECORDING_DURATION=300
# Duración máxima de grabación en segundos (300 = 5 minutos)
# Dejar como está

RECORDING_TIME_LABEL=1-5 min
# Etiqueta visible en la UI (texto informativo)
# Dejar como está

TASK_TEXT=Describe the picture.
# Tarea que debe realizar el alumno
# Dejar como está

IMAGE_PATH=../img/imagenes/
#IMAGE_PATH=./public_html/img/imagenes/
# Ruta donde están las imágenes para el prompt
# Dejar como está (relativa, se resuelve desde la raíz)

# ============================================================
# FFMPEG (Procesamiento de video)
# ============================================================

FFMPEG_BIN=ffmpeg
# Si no está en PATH, usar ruta absoluta: /usr/bin/ffmpeg
# Binario de FFmpeg en el servidor
# Disponible en SiteGround: /usr/bin/ffmpeg
# Dejar como "ffmpeg" si está en PATH (típico en SiteGround)

# ============================================================
# RESUMEN DE CAMBIOS CRÍTICOS DE LOCAL → SITEGROUND
# ============================================================
#
# Cambio 1: APP_ENV=production + APP_DEBUG=false
# Cambio 2: DB_DRIVER=mysql + credenciales reales
# Cambio 3: GROQ_API_KEY con plan de pago (NO vacío)
# Cambio 4: SMTP_HOST y SMTP_PASSWORD reales (NO vacíos)
# Cambio 5: STORAGE_LOCAL_PATH con ruta absoluta de SiteGround
#
# TODO LO DEMÁS: IGUAL que en local
#
# ============================================================
